# SPA fallback for BrowserRouter routes under /v2/
# Keeps direct refreshes like /v2/editor from returning server 404.

<IfModule mod_negotiation.c>
  Options -MultiViews
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /v2/

  # Let real files and directories resolve normally.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route everything else to the SPA entrypoint.
  RewriteRule ^ index.html [L]
</IfModule>
